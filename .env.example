# Application
APP_NAME=Finance Engine API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# Database
POSTGRES_DB=finance_engine
POSTGRES_USER=finance_engine
POSTGRES_PASSWORD=finance_engine
DATABASE_URL=postgresql+psycopg://finance_engine:finance_engine@postgres:5432/finance_engine

# Queue / worker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# AI providers
AI_PROVIDER=fallback
OPENAI_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
